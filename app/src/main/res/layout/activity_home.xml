<?xml version="1.0" encoding="utf-8"?>
<!-- Homepage Screen - Quetta Browser style -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F0">

    <!-- ── MAIN CONTENT ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top right edit/menu button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageButton
                android:id="@+id/btn_menu_home"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="#555555" />

        </RelativeLayout>

        <!-- ── BIG APP NAME - Center of screen ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- App Name -->
            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Video
Downloader"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#E8194B"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="48dp" />

            <!-- ── SHORTCUT ICONS ROW ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Google Shortcut -->
                <LinearLayout
                    android:id="@+id/shortcut_google"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="G"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#4285F4"
                        android:gravity="center"
                        android:background="@drawable/shortcut_bg_white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Google"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

                <!-- DuckDuckGo Shortcut -->
                <LinearLayout
                    android:id="@+id/shortcut_ddg"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🦆"
                        android:textSize="26sp"
                        android:gravity="center"
                        android:background="@drawable/shortcut_bg_white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DuckDuckGo"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

                <!-- YouTube Shortcut -->
                <LinearLayout
                    android:id="@+id/shortcut_youtube"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="▶"
                        android:textSize="26sp"
                        android:textColor="#FF0000"
                        android:gravity="center"
                        android:background="@drawable/shortcut_bg_white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YouTube"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

                <!-- Add Shortcut -->
                <LinearLayout
                    android:id="@+id/shortcut_add"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="+"
                        android:textSize="32sp"
                        android:textColor="#888888"
                        android:gravity="center"
                        android:background="@drawable/shortcut_bg_grey" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── BOTTOM SEARCH BAR (Quetta style) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:background="#F0F0F0">

            <!-- Search/URL Input -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/search_bar_home_bg"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <EditText
                    android:id="@+id/home_search_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search or type URL"
                    android:hintTextColor="#999999"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:background="@null"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:singleLine="true" />

                <!-- Tab count badge -->
                <TextView
                    android:id="@+id/tv_tab_count"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="1"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/tab_count_bg"
                    android:layout_marginEnd="4dp" />

            </LinearLayout>

            <!-- 3-dot menu button -->
            <ImageButton
                android:id="@+id/btn_home_overflow"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_more"
                android:tint="#555555"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
